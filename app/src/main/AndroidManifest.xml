<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Context gate (Layer 1): ActivityRecognition needs this on Android 10+. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Overlay renderer (Layer 3): draw dots over other apps. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground Service that keeps the sensor pipeline + overlay alive
         system-wide while the user leaves the app. API 34 requires an
         explicit foregroundServiceType + the matching permission below. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- The foreground notification (API 33+ needs runtime grant). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Optional confirmation signals for the context gate. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- The feature benefits from an accelerometer + gyro but degrades
         gracefully; don't hard-require them so it installs everywhere. -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />
    <uses-feature android:name="android.hardware.sensor.gyroscope" android:required="false" />

    <application
        android:name=".VmcApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VmcCues"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.VmcCues">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Layer 3: the overlay. A foreground Service owns the WindowManager
             view + the live sensor pipeline. Started/stopped from the
             settings UI or the Quick Settings tile. -->
        <service
            android:name=".overlay.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Accessibility-style motion-cue overlay for passengers" />
        </service>

        <!-- Layer 4: Quick Settings tile (Control Center equivalent). -->
        <service
            android:name=".tile.VmcTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile"
            android:label="@string/qs_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Receives ActivityRecognition updates; forwarded to the gate. -->
        <receiver
            android:name=".gate.ActivityRecognitionReceiver"
            android:exported="false" />

    </application>
</manifest>
